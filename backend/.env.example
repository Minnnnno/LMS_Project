# Runtime mode. Secure cookies and strict secret requirements are enabled in production.
APP_ENV=development

# Use a stable, randomly generated value containing at least 64 characters.
# Never commit the real value.
SESSION_SECRET=replace-me-with-64-or-more-random-characters-before-running-the-app

# Exact browser origin allowed to call the API. Do not include a path or trailing slash.
CORS_ALLOWED_ORIGIN=http://127.0.0.1:8080
FRONTEND_URL=http://127.0.0.1:8080

DATABASE_URL=postgres://username:password@localhost/database_name

SMTP_HOST=smtp.example.com
SMTP_USERNAME=sender@example.com
SMTP_PASSWORD=replace-me
